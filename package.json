{
  "name": "olse-receiver-accelerator",
  "version": "0.0.1",
  "type": "module",
  "description": "A reference repository to help accelerate the development of a GOV.UK One Login Signal Exchange Receiver",
  "scripts": {
    "prepare": "husky",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "type-check": "tsc --noEmit",
    "container:build": "CONTAINER=true node esbuild.config.mjs",
    "container:dev": "nodemon --exec tsx examples/express-container/server.ts",
    "lambda:build": "AWS_LAMBDA_REFERENCE=true node esbuild.config.mjs",
    "test:vendor": "vitest run --project vendor/unit --config tests/vendor/unit/vitest.config.ts",
    "test:vendor:build": "vitest run --project vendor/build",
    "test:vendor:staging": "vitest run --project vendor/staging",
    "test:unit": "vitest run --project implementor/unit --config tests/implementor/unit/vitest.config.ts",
    "tsFile": "tsx"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/govuk-one-login/olse-receiver-accelerator.git"
  },
  "author": "GOV.UK One Login",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/govuk-one-login/olse-receiver-accelerator/issues"
  },
  "homepage": "https://github.com/govuk-one-login/olse-receiver-accelerator#readme",
  "devDependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1075.0",
    "@aws-sdk/client-secrets-manager": "^3.1075.0",
    "@eslint/js": "^9.39.1",
    "@types/aws-lambda": "^8.10.159",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "concurrently": "^10.0.3",
    "dotenv": "^17.2.3",
    "esbuild": "^0.27.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nodemon": "^3.1.11",
    "prettier": "3.7.3",
    "supertest": "^7.1.4",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.1.9",
    "yaml-cfn": "^0.3.2"
  },
  "lint-staged": {
    "*": "npm run format:fix",
    "*.{js,ts}": "npm run lint:fix"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1075.0",
    "@aws-sdk/client-kms": "^3.1075.0",
    "@aws-lambda-powertools/logger": "^2.33.1",
    "@aws-sdk/client-cloudformation": "^3.1075.0",
    "@aws-sdk/client-secrets-manager": "^3.1075.0",
    "@aws-sdk/client-ssm": "^3.1075.0",
    "aws-jwt-verify": "^5.2.1",
    "express": "^5.2.1",
    "fs": "^0.0.1-security",
    "jose": "^6.2.3"
  }
}
